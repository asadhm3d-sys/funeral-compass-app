# Funeral Compass — optional Supabase backend
# Without these, the app runs in local demo mode (plans stored in the browser).
# 1. Create a Supabase project (choose an EU region, e.g. Frankfurt)
# 2. Run supabase/schema.sql in the SQL editor
# 3. Enable Email (magic link) auth in Authentication settings
# 4. Fill in and copy this file to .env
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Provider branding (optional) ────────────────────────────────────────────
# Without these the app shows neutral demo placeholders (e.g. "Funeral Home
# (Demo)").  Set them in a private .env file (never commit real values) to
# enable real branding without any code changes.  On Vercel, add them as
# Environment Variables in the project settings.
#
# VITE_PROVIDER_NAME=
# VITE_PROVIDER_PHONE_DISPLAY=
# VITE_PROVIDER_PHONE_TEL=
# VITE_PROVIDER_STREET=
# VITE_PROVIDER_CITY=
# VITE_PROVIDER_TAX_ID=
# VITE_PROVIDER_OFFICES=          # comma-separated, e.g. "Main office,Branch office"

# ── Email confirmation (Resend) ──────────────────────────────────────────────
# Sign up at resend.com and create an API key.
# RESEND_FROM requires a verified sending domain; omit to use the Resend test
# address (onboarding@resend.dev) which only delivers to your Resend account.
#
# RESEND_API_KEY=
# RESEND_FROM=                    # e.g. "Funeral Compass <hello@yourdomain.com>"
# RESEND_TO=                      # inbox for contact-form & plan-submission notifications (contact form defaults to sender's email if unset; plan submissions are only forwarded if this is set)
